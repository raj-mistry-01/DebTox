NODE_ENV=development
PORT=8000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=split_backend
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://user:password@host:5432

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=replace_with_google_web_client_id

# ── UroPay Variables ──────────────────────────────────────────────────────────
UROPAY_API_KEY=replace_with_uropay_api_key
UROPAY_SECRET=replace_with_uropay_secret
UROPAY_VPA=replace_with_vpa
UROPAY_VPA_NAME=replace_with_vpa_name

# End of config
